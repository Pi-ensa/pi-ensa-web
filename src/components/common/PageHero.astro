---
interface Props { eyebrow?: string; title: string; description?: string } const { eyebrow='PI-ENSA', title, description } = Astro.props;
---
<section class="section bg-[var(--surface)]"><div class="container"><p class="eyebrow">{eyebrow}</p><h1 class="display mt-3 font-extrabold">{title}</h1>{description && <p class="lead mt-6">{description}</p>}</div></section>
