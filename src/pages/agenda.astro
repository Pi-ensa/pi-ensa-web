---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/common/PageHero.astro'; import { workshopSchedule2026 } from '../data/site-data';
---
<BaseLayout title="Agenda de talleres 2026 | PI-ENSA" description="Fechas de los ocho talleres PI-ENSA programados entre febrero y mayo de 2026."><PageHero eyebrow="Febrero–mayo de 2026" title="Agenda de talleres" description="Fechas de los ocho bloques de talleres, organizadas por el día de asistencia de cada grupo."/><section class="section"><div class="container"><div class="notice mb-8"><strong>Periodo concluido.</strong> Esta agenda corresponde al ciclo 2026 y se conserva como referencia. Las fechas exactas variaron según el día asignado a cada grupo.</div><div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">{workshopSchedule2026.map((group)=><article class="card"><p class="eyebrow">Grupo</p><h2 class="mt-2 text-2xl font-extrabold">{group.day}</h2><ol class="schedule-list">{group.sessions.map((session)=><li>{session}</li>)}</ol></article>)}</div><p class="mt-8 text-sm text-[var(--muted)]">El calendario contempló pausas por ExpoUDLAP, Semana Santa, Pascua y días sin actividad.</p></div></section></BaseLayout>
