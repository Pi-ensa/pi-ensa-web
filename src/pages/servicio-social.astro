---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/common/PageHero.astro';
import { studentProcessDates, studentProcessSettings } from '../utils/student-process';
---

<BaseLayout title="Proceso de servicio social | PI-ENSA" description="Fechas del proceso de aceptación de estudiantes UDLAP en PI-ENSA.">
  <PageHero
    title="Proceso de aceptación para estudiantes UDLAP"
    description="Consulta el calendario del proceso de servicio social de PI-ENSA."
  />

  <section class="section">
    <div class="container max-w-5xl">
      <div class="notice">
        <strong>{studentProcessSettings.status}</strong>{' '}{studentProcessSettings.message}
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {studentProcessDates.map((item, index) => (
          <article class="card relative overflow-hidden">
            <span class="absolute right-5 top-4 text-5xl font-black text-[var(--primary)]/10" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
            <p class="eyebrow">{item.date}</p>
            <h2 class="mt-2 pr-12 text-2xl font-bold">{item.title}</h2>
            <p class="mt-3 text-[var(--muted)]">{item.description}</p>
          </article>
        ))}
      </div>

      {studentProcessSettings.note && <p class="mt-8 text-sm text-[var(--muted)]">{studentProcessSettings.note}</p>}
    </div>
  </section>
</BaseLayout>
