---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/common/PageHero.astro'; import { thematicAreas } from '../data/site-data'; import { workshopOffer } from '../utils/workshop-offer'; import { withBase } from '../utils/paths';
---
<BaseLayout title="Talleres | PI-ENSA" description="Consulta los talleres y carteles publicados por PI-ENSA."><PageHero title="Aprender ciencia haciéndola" description="Consulta el nombre, la descripción y el cartel informativo de cada taller ofertado."/><section class="section"><div class="container">{workshopOffer.length ? <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">{workshopOffer.map((workshop)=><article class="card card-link flex flex-col"><p class="eyebrow">Taller PI-ENSA</p><h2 class="mt-2 text-2xl font-bold">{workshop.name}</h2><p class="mt-3 flex-1 text-[var(--muted)]">{workshop.description}</p><a class="button mt-6" href={withBase(workshop.posterPdf)} target="_blank" rel="noopener noreferrer">Ver cartel en PDF <span class="sr-only">(abre en otra pestaña)</span></a></article>)}</div> : <div class="notice"><strong>Próxima oferta en preparación.</strong> Los talleres aparecerán aquí cuando sus carteles estén publicados.</div>}<section class="mt-14"><p class="eyebrow">Trayectoria temática</p><h2 class="mt-3 text-3xl font-extrabold">Áreas exploradas por PI-ENSA</h2><div class="mt-7 grid gap-5 md:grid-cols-2 lg:grid-cols-3">{thematicAreas.map((area)=><article class="card"><h3 class="text-xl font-bold text-[var(--primary)]">{area.name}</h3><p>{area.description}</p></article>)}</div></section></div></section></BaseLayout>
