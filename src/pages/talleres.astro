---
import BaseLayout from '../layouts/BaseLayout.astro'; import PageHero from '../components/common/PageHero.astro'; import { thematicAreas } from '../data/site-data'; import { withBase } from '../utils/paths';
---
<BaseLayout title="Talleres | PI-ENSA" description="Conoce las líneas temáticas y el enfoque de los talleres PI-ENSA."><PageHero title="Aprender ciencia haciéndola" description="La cartera de talleres cambia cada periodo. Estas son las líneas temáticas documentadas en la trayectoria del programa."/><section class="section"><div class="container"><div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">{thematicAreas.map((area) => <article class="card"><h2 class="text-xl font-bold text-[var(--primary)]">{area.name}</h2><p>{area.description}</p></article>)}</div><div class="notice mt-10"><strong>Oferta por confirmar.</strong> Los nombres, edades, horarios, cupos y modalidades de cada taller se publican en su convocatoria correspondiente.</div></div></section><section class="section bg-[var(--surface)]"><div class="container grid gap-8 md:grid-cols-2"><article><p class="eyebrow">Ejemplos históricos</p><h2 class="mt-3 text-3xl font-extrabold">Actividades documentadas</h2><p class="lead mt-4">Robótica, programación, instrumentación, bioingeniería, diseño de productos, ingeniería civil y ambiental, física, química, biomédica, matemáticas, dibujo e inglés por computadora.</p></article><article class="card"><h2 class="text-2xl font-bold">Consulta la convocatoria 2026</h2><p>El cartel conserva las indicaciones y fechas del periodo iniciado en febrero de 2026. Se publica como documento de archivo.</p><a class="button mt-5" href={withBase('/documentos/cartel-convocatoria-pi-ensa-2026.pdf')} target="_blank" rel="noopener noreferrer">Abrir cartel en PDF <span class="sr-only">(abre en otra pestaña)</span></a></article></div></section></BaseLayout>
