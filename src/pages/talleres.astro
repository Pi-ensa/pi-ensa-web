---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/common/PageHero.astro';
import { registrationBanner, workshopOffer } from '../utils/workshop-offer';
import { withBase } from '../utils/paths';
---

<BaseLayout title="Talleres | PI-ENSA" description="Consulta la oferta de talleres y sus carteles informativos.">
  <PageHero
    title="Talleres ofertados"
    description="Consulta los talleres y carteles informativos disponibles."
  />

  <section class="section">
    <div class="container">
      <aside class="rounded-3xl border border-white/20 bg-[var(--primary)] p-6 text-white shadow-lg md:p-8" aria-labelledby="registration-status">
        <h2 id="registration-status" class="text-3xl font-extrabold">{registrationBanner.status}</h2>
        <div class="mt-5 grid gap-3 md:grid-cols-2">
          <p class="rounded-2xl bg-white/10 p-4"><strong>Inscripciones:</strong><br />{registrationBanner.registrationDates}</p>
          <p class="rounded-2xl bg-white/10 p-4"><strong>Inscripciones extemporáneas:</strong><br />{registrationBanner.lateRegistration}</p>
        </div>
      </aside>

      {
        workshopOffer.length > 0 && (
          <section class="mt-14" aria-labelledby="current-offer">
            <h2 id="current-offer" class="text-3xl font-extrabold">Talleres ofertados</h2>
            <div class="mt-7 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {workshopOffer.map((workshop) => (
                <article class="card card-link flex flex-col">
                  <h3 class="text-2xl font-bold">{workshop.name}</h3>
                  <p class="mt-3 flex-1 text-[var(--muted)]">{workshop.description}</p>
                  <a class="button mt-6" href={withBase(workshop.posterPdf)} target="_blank" rel="noopener noreferrer">
                    Ver cartel en PDF <span class="sr-only">(abre en otra pestaña)</span>
                  </a>
                </article>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </section>
</BaseLayout>
