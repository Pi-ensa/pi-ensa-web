---
import { getCollection } from 'astro:content'; import BaseLayout from '../../layouts/BaseLayout.astro'; import PageHero from '../../components/common/PageHero.astro'; import { withBase } from '../../utils/paths'; const entries=(await getCollection('news',({data})=>!data.draft)).sort((a,b)=>b.data.publishedDate.valueOf()-a.data.publishedDate.valueOf());
---
<BaseLayout title="Noticias | PI-ENSA"><PageHero title="Noticias y convocatorias"/><section class="section"><div class="container grid gap-6 md:grid-cols-2">{entries.map((entry)=><article class="card"><time class="text-sm text-[var(--muted)]" datetime={entry.data.publishedDate.toISOString()}>{entry.data.publishedDate.toLocaleDateString('es-MX',{year:'numeric',month:'long',day:'numeric'})}</time><h2 class="mt-2 text-2xl font-bold"><a href={withBase(`/noticias/${entry.id}/`)}>{entry.data.title}</a></h2><p>{entry.data.summary}</p></article>)}</div></section></BaseLayout>
