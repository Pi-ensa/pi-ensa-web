---
import { getCollection, render, type CollectionEntry } from 'astro:content'; import BaseLayout from '../../layouts/BaseLayout.astro'; import PageHero from '../../components/common/PageHero.astro'; export async function getStaticPaths(){return (await getCollection('news',({data})=>!data.draft)).map(entry=>({params:{id:entry.id},props:{entry}}));} interface Props{entry:CollectionEntry<'news'>} const {entry}=Astro.props; const {Content}=await render(entry);
---
<BaseLayout title={`${entry.data.title} | PI-ENSA`} description={entry.data.summary}><PageHero eyebrow="Noticias" title={entry.data.title} description={entry.data.summary}/><article class="section"><div class="container prose"><Content/></div></article></BaseLayout>
