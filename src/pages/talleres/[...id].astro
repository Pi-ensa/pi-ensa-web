---
import { getCollection, render, type CollectionEntry } from 'astro:content'; import BaseLayout from '../../layouts/BaseLayout.astro'; import PageHero from '../../components/common/PageHero.astro'; import { SITE } from '../../config/site'; export async function getStaticPaths(){return (await getCollection('workshops',({data})=>!data.draft)).map(entry=>({params:{id:entry.id},props:{entry}}));} interface Props{entry:CollectionEntry<'workshops'>} const {entry}=Astro.props; const {Content}=await render(entry); const registration=entry.data.registrationUrl || `mailto:${SITE.contactEmail}?subject=Inscripción: ${encodeURIComponent(entry.data.title)}`;
---
<BaseLayout title={`${entry.data.title} | PI-ENSA`} description={entry.data.summary}><PageHero eyebrow={entry.data.area} title={entry.data.title} description={entry.data.summary}/><section class="section"><div class="container grid gap-10 lg:grid-cols-[1fr_22rem]"><article class="prose"><Content/></article><aside class="card self-start"><dl class="space-y-4"><div><dt class="font-bold">Estado</dt><dd>{entry.data.status}</dd></div><div><dt class="font-bold">Dirigido a</dt><dd>{entry.data.audience}</dd></div><div><dt class="font-bold">Fechas</dt><dd>{entry.data.dates}</dd></div><div><dt class="font-bold">Horario</dt><dd>{entry.data.schedule}</dd></div><div><dt class="font-bold">Modalidad</dt><dd>{entry.data.modality}</dd></div></dl><a class="button mt-6 w-full" href={registration} target={entry.data.registrationUrl ? '_blank' : undefined} rel={entry.data.registrationUrl ? 'noopener noreferrer' : undefined}>Inscríbete</a></aside></div></section></BaseLayout>
